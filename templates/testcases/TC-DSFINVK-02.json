    "$time1": "Zeitstempel der Signaturerstellung (time1)",
    "$tn1": "Transaktionsnummer (Rückgabe startTransaction, tn1)",
    "$type1": "Übergabewert für processType (type1)",
    "$type2": "Übergabewert für processType (type2)"
  },
